<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AgentAI – Workflows</title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>
<body>
    <div class="container">
        <nav class="sidebar">
            <div class="logo">
                <div class="logo-icon">⬡</div>
                <span>AgentAI</span>
            </div>
            <ul>
                <li><a href="/"><i class="fas fa-home"></i> Home</a></li>
                <li><a href="/agents"><i class="fas fa-user-friends"></i> Agents</a></li>
                <li class="active"><a href="/workflows"><i class="fas fa-cogs"></i> Workflows</a></li>
                <li><a href="/analytics"><i class="fas fa-chart-bar"></i> Analytics</a></li>
                <li><a href="/settings"><i class="fas fa-cog"></i> Settings</a></li>
            </ul>
        </nav>

        <main class="main-content main-content--full">
            <header class="header">
                <div class="search-bar">
                    <i class="fas fa-search"></i>
                    <input type="text" id="workflowSearch" placeholder="Filter workflows…">
                </div>
                <div class="actions">
                    <div class="agent-status">
                        <span>Agent</span>
                        <span class="status-indicator"></span>
                        <span>Running</span>
                    </div>
                    <button class="icon-button notification" aria-label="Notifications"></button>
                    <div class="profile"><div class="avatar-placeholder"></div></div>
                </div>
            </header>

            <div class="content">
                <div class="greeting">
                    <div class="kicker">Workflow Center</div>
                    <h1>Automations that keep moving.</h1>
                    <p>Chain agents, APIs, and tasks into repeatable, observable business flows.</p>
                </div>

                <!-- Run log toast -->
                <div id="runToast" class="run-toast" hidden>
                    <i class="fas fa-circle-notch fa-spin"></i>
                    <span id="runToastMsg">Starting workflow…</span>
                </div>

                <section class="card-grid" id="workflowGrid">
                    <article class="workflow-card" data-name="Lead Discovery">
                        <div class="workflow-card-header">
                            <div class="workflow-badge"><i class="fas fa-magnifying-glass-chart"></i></div>
                            <div>
                                <h3>Lead Discovery → Follow-up</h3>
                                <p class="muted">Automated sales workflow</p>
                            </div>
                        </div>
                        <p>Search new prospects, summarise intent, and create follow-up tasks — no manual copying.</p>
                        <div class="workflow-steps">
                            <span class="step-chip"><i class="fas fa-search"></i> Search</span>
                            <i class="fas fa-chevron-right step-arrow"></i>
                            <span class="step-chip"><i class="fas fa-brain"></i> Summarise</span>
                            <i class="fas fa-chevron-right step-arrow"></i>
                            <span class="step-chip"><i class="fas fa-check-square"></i> Task</span>
                        </div>
                        <div class="card-actions">
                            <button class="primary-btn run-btn" data-workflow="Lead Discovery → Follow-up">
                                <i class="fas fa-play"></i> Run Workflow
                            </button>
                            <button class="secondary-btn inspect-btn">Inspect Steps</button>
                        </div>
                        <div class="last-run">Last run: <strong>2 min ago</strong> · <span class="badge badge--success">Success</span></div>
                    </article>

                    <article class="workflow-card" data-name="Insight Brief">
                        <div class="workflow-card-header">
                            <div class="workflow-badge"><i class="fas fa-chart-line"></i></div>
                            <div>
                                <h3>Insight Brief Generator</h3>
                                <p class="muted">Analytics summary pipeline</p>
                            </div>
                        </div>
                        <p>Turn raw business events into clean summaries for founders, operators, and growth teams.</p>
                        <div class="workflow-steps">
                            <span class="step-chip"><i class="fas fa-database"></i> Ingest</span>
                            <i class="fas fa-chevron-right step-arrow"></i>
                            <span class="step-chip"><i class="fas fa-brain"></i> Analyse</span>
                            <i class="fas fa-chevron-right step-arrow"></i>
                            <span class="step-chip"><i class="fas fa-file-lines"></i> Report</span>
                        </div>
                        <div class="card-actions">
                            <button class="primary-btn run-btn" data-workflow="Insight Brief Generator">
                                <i class="fas fa-play"></i> Generate Brief
                            </button>
                            <button class="secondary-btn">Edit Rules</button>
                        </div>
                        <div class="last-run">Last run: <strong>15 min ago</strong> · <span class="badge badge--success">Success</span></div>
                    </article>

                    <article class="workflow-card" data-name="Alert">
                        <div class="workflow-card-header">
                            <div class="workflow-badge"><i class="fas fa-bell"></i></div>
                            <div>
                                <h3>Alert + Escalation</h3>
                                <p class="muted">Issue handling workflow</p>
                            </div>
                        </div>
                        <p>Route critical events to the right agent, create a task, and notify the owner in real time.</p>
                        <div class="workflow-steps">
                            <span class="step-chip"><i class="fas fa-bolt"></i> Trigger</span>
                            <i class="fas fa-chevron-right step-arrow"></i>
                            <span class="step-chip"><i class="fas fa-route"></i> Route</span>
                            <i class="fas fa-chevron-right step-arrow"></i>
                            <span class="step-chip"><i class="fas fa-bell"></i> Notify</span>
                        </div>
                        <div class="card-actions">
                            <button class="primary-btn run-btn" data-workflow="Alert + Escalation">
                                <i class="fas fa-play"></i> Preview Flow
                            </button>
                            <button class="secondary-btn">Clone</button>
                        </div>
                        <div class="last-run">Last run: <strong>1 hr ago</strong> · <span class="badge badge--success">Success</span></div>
                    </article>
                </section>
            </div>
        </main>
    </div>

    <nav class="mobile-nav">
        <a href="/"><i class="fas fa-home"></i><span>Home</span></a>
        <a href="/agents"><i class="fas fa-user-friends"></i><span>Agents</span></a>
        <a href="/workflows" class="active"><i class="fas fa-cogs"></i><span>Workflows</span></a>
        <a href="/settings"><i class="fas fa-cog"></i><span>Settings</span></a>
    </nav>

    <script>
    (() => {
      const toast    = document.getElementById('runToast');
      const toastMsg = document.getElementById('runToastMsg');

      // ── Run buttons ────────────────────────────────────────────────────────
      document.querySelectorAll('.run-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const name = btn.dataset.workflow;
          const card = btn.closest('.workflow-card');
          showToast(`Running "${name}"…`);
          btn.disabled = true;

          // Simulate a workflow run (replace with real API call)
          await sleep(2200);

          const lastRun = card.querySelector('.last-run');
          lastRun.innerHTML = `Last run: <strong>just now</strong> · <span class="badge badge--success">Success</span>`;
          showToast(`"${name}" completed successfully.`, 'success');
          btn.disabled = false;
          setTimeout(hideToast, 3000);
        });
      });

      // ── Inspect buttons ────────────────────────────────────────────────────
      document.querySelectorAll('.inspect-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          showToast('Step inspector coming soon.', 'info');
          setTimeout(hideToast, 2500);
        });
      });

      // ── Search filter ──────────────────────────────────────────────────────
      document.getElementById('workflowSearch').addEventListener('input', (e) => {
        const q = e.target.value.toLowerCase();
        document.querySelectorAll('.workflow-card').forEach(card => {
          card.style.display = card.dataset.name.toLowerCase().includes(q) ? '' : 'none';
        });
      });

      function showToast(msg, type = 'loading') {
        toastMsg.textContent = msg;
        toast.className = `run-toast run-toast--${type}`;
        toast.hidden = false;
        const icon = toast.querySelector('i');
        icon.className = type === 'loading'
          ? 'fas fa-circle-notch fa-spin'
          : type === 'success'
            ? 'fas fa-circle-check'
            : 'fas fa-circle-info';
      }
      function hideToast() { toast.hidden = true; }
      function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }
    })();
    </script>
</body>
</html>
