<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AgentAI<%= agent ? ' · ' + agent.name : '' %></title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>
<body>
    <div class="container">
        <nav class="sidebar">
            <div class="logo">
                <div class="logo-icon">⬡</div>
                <span>AgentAI</span>
            </div>
            <ul>
                <li class="active"><a href="/"><i class="fas fa-home"></i> Home</a></li>
                <li><a href="/agents"><i class="fas fa-user-friends"></i> Agents</a></li>
                <li><a href="/workflows"><i class="fas fa-cogs"></i> Workflows</a></li>
                <li><a href="/analytics"><i class="fas fa-chart-bar"></i> Analytics</a></li>
                <li><a href="/settings"><i class="fas fa-cog"></i> Settings</a></li>
            </ul>
        </nav>

        <main class="main-content">
            <header class="header">
                <div class="search-bar">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Search commands..." id="globalSearch">
                </div>
                <div class="actions">
                    <div class="agent-status" id="agentStatusBadge">
                        <span>Agent</span>
                        <span class="status-indicator" id="statusDot"></span>
                        <span id="statusLabel">Online</span>
                    </div>
                    <button class="icon-button notification" aria-label="Notifications"></button>
                    <div class="profile">
                        <div class="avatar-placeholder" aria-label="Profile"></div>
                    </div>
                </div>
            </header>

            <div class="content">
                <div class="greeting">
                    <div class="kicker"><%= agent ? agent.name : 'Agent Dashboard' %></div>
                    <h1>Hello, let's build.</h1>
                    <p><%= agent ? agent.description : 'Choose an agent below or type a command to get started.' %></p>
                </div>

                <div class="chat-container">
                    <div class="chat-input">
                        <input
                            type="text"
                            id="chatInput"
                            placeholder="<%= agent ? agent.suggestions[0] : 'Ask your agent anything…' %>"
                            autocomplete="off"
                        >
                        <button class="send-button" id="sendBtn" aria-label="Send">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </div>

                    <div class="chat-suggestions" id="suggestionsBar">
                        <% const suggestions = agent && agent.suggestions
                            ? agent.suggestions
                            : ['Find business leads', 'Create a task', 'Analyze data']; %>
                        <% suggestions.forEach((s) => { %>
                            <button class="suggestion-chip"><%= s %></button>
                        <% }) %>
                    </div>

                    <div class="chat-history" id="chatHistory">
                        <!-- messages injected by JS -->
                    </div>
                </div>
            </div>

            <aside class="right-sidebar">
                <div class="quick-actions">
                    <h2>Quick Actions</h2>
                    <button onclick="fillChat('Search for new leads')"><i class="fas fa-search"></i> Search Leads</button>
                    <button onclick="fillChat('Create a follow-up task')"><i class="fas fa-check-square"></i> Create Task</button>
                    <button onclick="location.href='/analytics'"><i class="fas fa-chart-bar"></i> Analytics</button>
                    <button onclick="location.href='/workflows'"><i class="fas fa-cogs"></i> Workflows</button>
                </div>
                <div class="recent-activity">
                    <h2>Recent Activity</h2>
                    <ul id="activityFeed">
                        <li>
                            <div class="activity-icon"><i class="fas fa-robot"></i></div>
                            <div class="activity-details">
                                <p>Agent ready</p>
                                <span>Start a conversation above.</span>
                            </div>
                            <div class="activity-time">now</div>
                        </li>
                    </ul>
                </div>
            </aside>
        </main>
    </div>

    <nav class="mobile-nav">
        <a href="/" class="active"><i class="fas fa-home"></i><span>Home</span></a>
        <a href="/agents"><i class="fas fa-user-friends"></i><span>Agents</span></a>
        <a href="/workflows"><i class="fas fa-cogs"></i><span>Workflows</span></a>
        <a href="/settings"><i class="fas fa-cog"></i><span>Settings</span></a>
    </nav>

    <script>
    (() => {
      // ── State ──────────────────────────────────────────────────────────────
      let sessionId = sessionStorage.getItem('agentai_session') || null;
      let isStreaming = false;

      const chatHistory   = document.getElementById('chatHistory');
      const chatInput     = document.getElementById('chatInput');
      const sendBtn       = document.getElementById('sendBtn');
      const statusDot     = document.getElementById('statusDot');
      const statusLabel   = document.getElementById('statusLabel');
      const activityFeed  = document.getElementById('activityFeed');

      // ── Suggestion chips ───────────────────────────────────────────────────
      document.querySelectorAll('.suggestion-chip').forEach(btn => {
        btn.addEventListener('click', () => {
          chatInput.value = btn.textContent;
          chatInput.focus();
        });
      });

      // ── Quick-action helper ────────────────────────────────────────────────
      window.fillChat = (text) => {
        chatInput.value = text;
        chatInput.focus();
      };

      // ── Send on Enter ──────────────────────────────────────────────────────
      chatInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
      });
      sendBtn.addEventListener('click', sendMessage);

      // ── Core send logic ────────────────────────────────────────────────────
      async function sendMessage() {
        const text = chatInput.value.trim();
        if (!text || isStreaming) return;

        chatInput.value = '';
        appendUserMessage(text);
        setStatus('thinking', 'Thinking…');
        isStreaming = true;
        sendBtn.disabled = true;

        const agentBubble = appendAgentBubble();

        try {
          const res = await fetch('/api/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ message: text, sessionId }),
          });

          if (!res.ok) {
            const err = await res.json().catch(() => ({ error: 'Unknown error' }));
            agentBubble.innerHTML = `<span class="error-text"><i class="fas fa-triangle-exclamation"></i> ${err.error}</span>`;
            setStatus('error', 'Error');
            return;
          }

          // ── SSE stream ───────────────────────────────────────────────────
          const reader  = res.body.getReader();
          const decoder = new TextDecoder();
          let buffer = '';
          let fullText = '';

          setStatus('streaming', 'Responding…');

          while (true) {
            const { value, done } = await reader.read();
            if (done) break;

            buffer += decoder.decode(value, { stream: true });
            const lines = buffer.split('\n');
            buffer = lines.pop(); // keep incomplete line

            let eventName = '';
            for (const line of lines) {
              if (line.startsWith('event:')) {
                eventName = line.slice(6).trim();
              } else if (line.startsWith('data:')) {
                const payload = JSON.parse(line.slice(5).trim());

                if (eventName === 'chunk') {
                  fullText += payload.text;
                  agentBubble.innerHTML = renderMarkdown(fullText) + '<span class="cursor">▍</span>';
                  chatHistory.scrollTop = chatHistory.scrollHeight;

                } else if (eventName === 'done') {
                  sessionId = payload.sessionId;
                  sessionStorage.setItem('agentai_session', sessionId);
                  agentBubble.innerHTML = renderMarkdown(fullText);
                  setStatus('online', 'Online');
                  addActivity('Agent replied', truncate(fullText, 60));

                } else if (eventName === 'error') {
                  agentBubble.innerHTML = `<span class="error-text"><i class="fas fa-triangle-exclamation"></i> ${payload.message}</span>`;
                  setStatus('error', 'Error');
                }
                eventName = '';
              }
            }
          }
        } catch (e) {
          console.error(e);
          agentBubble.innerHTML = `<span class="error-text"><i class="fas fa-triangle-exclamation"></i> Connection error. Is the server running?</span>`;
          setStatus('error', 'Error');
        } finally {
          isStreaming = false;
          sendBtn.disabled = false;
          chatInput.focus();
        }
      }

      // ── DOM helpers ────────────────────────────────────────────────────────
      function appendUserMessage(text) {
        const el = document.createElement('div');
        el.className = 'chat-message user-message';
        el.innerHTML = `
          <div class="message-content"><p>${escapeHtml(text)}</p></div>
          <div class="message-time">${now()}</div>`;
        chatHistory.appendChild(el);
        chatHistory.scrollTop = chatHistory.scrollHeight;
        addActivity('You sent a message', truncate(text, 60));
      }

      function appendAgentBubble() {
        const el = document.createElement('div');
        el.className = 'chat-message agent-message';
        el.innerHTML = `
          <div class="message-content agent-typing">
            <span class="typing-dots"><span></span><span></span><span></span></span>
          </div>`;
        chatHistory.appendChild(el);
        chatHistory.scrollTop = chatHistory.scrollHeight;
        // Return reference to the inner content div
        const bubble = el.querySelector('.message-content');
        return bubble;
      }

      function addActivity(title, detail) {
        const li = document.createElement('li');
        li.innerHTML = `
          <div class="activity-icon"><i class="fas fa-robot"></i></div>
          <div class="activity-details"><p>${escapeHtml(title)}</p><span>${escapeHtml(detail)}</span></div>
          <div class="activity-time">${now()}</div>`;
        activityFeed.prepend(li);
        // Keep feed to last 8 items
        while (activityFeed.children.length > 8) activityFeed.removeChild(activityFeed.lastChild);
      }

      // ── Status badge ───────────────────────────────────────────────────────
      function setStatus(state, label) {
        statusLabel.textContent = label;
        statusDot.className = 'status-indicator';
        if (state === 'thinking' || state === 'streaming') statusDot.classList.add('pulsing');
        if (state === 'error') statusDot.classList.add('error');
      }

      // ── Minimal markdown → HTML (bold, code, newlines) ───────────────────
      function renderMarkdown(md) {
        return escapeHtml(md)
          .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
          .replace(/`([^`]+)`/g, '<code>$1</code>')
          .replace(/\n/g, '<br>');
      }

      function escapeHtml(s) {
        return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
      }
      function truncate(s, n) { return s.length > n ? s.slice(0, n) + '…' : s; }
      function now() {
        return new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      }
    })();
    </script>
</body>
</html>
