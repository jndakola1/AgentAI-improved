<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AgentAI – Settings</title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>
<body>
    <div class="container">
        <nav class="sidebar">
            <div class="logo">
                <div class="logo-icon">⬡</div>
                <span>AgentAI</span>
            </div>
            <ul>
                <li><a href="/"><i class="fas fa-home"></i> Home</a></li>
                <li><a href="/agents"><i class="fas fa-user-friends"></i> Agents</a></li>
                <li><a href="/workflows"><i class="fas fa-cogs"></i> Workflows</a></li>
                <li><a href="/analytics"><i class="fas fa-chart-bar"></i> Analytics</a></li>
                <li class="active"><a href="/settings"><i class="fas fa-cog"></i> Settings</a></li>
            </ul>
        </nav>

        <main class="main-content main-content--full">
            <header class="header">
                <div class="search-bar">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Search settings…">
                </div>
                <div class="actions">
                    <div class="agent-status">
                        <span>Workspace</span>
                        <span class="status-indicator"></span>
                        <span>Healthy</span>
                    </div>
                    <button class="icon-button notification" aria-label="Notifications"></button>
                    <div class="profile"><div class="avatar-placeholder"></div></div>
                </div>
            </header>

            <div class="content">
                <div class="greeting">
                    <div class="kicker">Settings</div>
                    <h1>Configure your platform.</h1>
                    <p>Fine-tune your AWS setup, agent prompts, and UX preferences.</p>
                </div>

                <div id="settingsSaved" class="settings-toast" hidden>
                    <i class="fas fa-circle-check"></i> Settings saved.
                </div>

                <div class="settings-layout">
                    <!-- AWS Config -->
                    <section class="setting-section">
                        <h2 class="section-title"><i class="fas fa-cloud"></i> AWS Configuration</h2>
                        <div class="field-group">
                            <label for="awsRegion">AWS Region</label>
                            <input id="awsRegion" type="text" class="settings-input" placeholder="us-east-1">
                        </div>
                        <div class="field-group">
                            <label for="agentId">Bedrock Agent ID</label>
                            <input id="agentId" type="text" class="settings-input" placeholder="XXXXXXXXXX">
                        </div>
                        <div class="field-group">
                            <label for="agentAliasId">Agent Alias ID</label>
                            <input id="agentAliasId" type="text" class="settings-input" placeholder="XXXXXXXXXX">
                        </div>
                        <p class="field-note"><i class="fas fa-lock"></i> These values are read-only in the UI — set them via environment variables on your server.</p>
                    </section>

                    <!-- Agent Prompts -->
                    <section class="setting-section">
                        <h2 class="section-title"><i class="fas fa-brain"></i> Agent Prompts</h2>
                        <div class="field-group">
                            <label for="systemPrompt">Default System Prompt</label>
                            <textarea id="systemPrompt" class="settings-textarea" rows="4" placeholder="You are a helpful business AI agent…"></textarea>
                        </div>
                        <div class="field-group">
                            <label for="fallbackMsg">Fallback Message</label>
                            <input id="fallbackMsg" type="text" class="settings-input" placeholder="I'm not sure how to help with that. Try rephrasing.">
                        </div>
                    </section>

                    <!-- UX Preferences -->
                    <section class="setting-section">
                        <h2 class="section-title"><i class="fas fa-sliders"></i> UX Preferences</h2>
                        <div class="toggle-row">
                            <div>
                                <p class="toggle-label">Streaming responses</p>
                                <p class="toggle-desc">Display agent replies word-by-word as they arrive.</p>
                            </div>
                            <label class="toggle-switch">
                                <input type="checkbox" id="toggleStreaming" checked>
                                <span class="toggle-track"><span class="toggle-thumb"></span></span>
                            </label>
                        </div>
                        <div class="toggle-row">
                            <div>
                                <p class="toggle-label">Sound notifications</p>
                                <p class="toggle-desc">Play a chime when the agent finishes a response.</p>
                            </div>
                            <label class="toggle-switch">
                                <input type="checkbox" id="toggleSound">
                                <span class="toggle-track"><span class="toggle-thumb"></span></span>
                            </label>
                        </div>
                        <div class="toggle-row">
                            <div>
                                <p class="toggle-label">Persist sessions</p>
                                <p class="toggle-desc">Keep conversation context across page reloads.</p>
                            </div>
                            <label class="toggle-switch">
                                <input type="checkbox" id="toggleSession" checked>
                                <span class="toggle-track"><span class="toggle-thumb"></span></span>
                            </label>
                        </div>
                    </section>

                    <!-- Danger zone -->
                    <section class="setting-section setting-section--danger">
                        <h2 class="section-title"><i class="fas fa-triangle-exclamation"></i> Danger Zone</h2>
                        <p>These actions are irreversible. Proceed with caution.</p>
                        <div class="card-actions" style="margin-top:14px">
                            <button class="danger-btn" id="clearSessionBtn">
                                <i class="fas fa-rotate"></i> Clear Session Memory
                            </button>
                        </div>
                    </section>

                    <div class="settings-footer">
                        <button class="primary-btn" id="saveBtn">Save Changes</button>
                        <button class="secondary-btn" id="resetBtn">Reset to Defaults</button>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <nav class="mobile-nav">
        <a href="/"><i class="fas fa-home"></i><span>Home</span></a>
        <a href="/agents"><i class="fas fa-user-friends"></i><span>Agents</span></a>
        <a href="/workflows"><i class="fas fa-cogs"></i><span>Workflows</span></a>
        <a href="/settings" class="active"><i class="fas fa-cog"></i><span>Settings</span></a>
    </nav>

    <script>
    (() => {
      const KEY = 'agentai_settings';
      const defaults = {
        awsRegion:     'us-east-1',
        agentId:       '',
        agentAliasId:  '',
        systemPrompt:  'You are a helpful business AI agent.',
        fallbackMsg:   "I'm not sure how to help with that. Try rephrasing.",
        streaming:     true,
        sound:         false,
        session:       true,
      };

      function load() {
        try { return { ...defaults, ...JSON.parse(localStorage.getItem(KEY) || '{}') }; }
        catch { return { ...defaults }; }
      }

      function save(s) { localStorage.setItem(KEY, JSON.stringify(s)); }

      function populate(s) {
        document.getElementById('awsRegion').value     = s.awsRegion;
        document.getElementById('agentId').value       = s.agentId;
        document.getElementById('agentAliasId').value  = s.agentAliasId;
        document.getElementById('systemPrompt').value  = s.systemPrompt;
        document.getElementById('fallbackMsg').value   = s.fallbackMsg;
        document.getElementById('toggleStreaming').checked = s.streaming;
        document.getElementById('toggleSound').checked     = s.sound;
        document.getElementById('toggleSession').checked   = s.session;
        // AWS fields are read-only in the UI
        ['awsRegion','agentId','agentAliasId'].forEach(id =>
          document.getElementById(id).setAttribute('readonly', true)
        );
      }

      populate(load());

      document.getElementById('saveBtn').addEventListener('click', () => {
        const s = load();
        s.systemPrompt = document.getElementById('systemPrompt').value;
        s.fallbackMsg  = document.getElementById('fallbackMsg').value;
        s.streaming    = document.getElementById('toggleStreaming').checked;
        s.sound        = document.getElementById('toggleSound').checked;
        s.session      = document.getElementById('toggleSession').checked;
        save(s);
        showToast();
      });

      document.getElementById('resetBtn').addEventListener('click', () => {
        save({ ...defaults });
        populate({ ...defaults });
        showToast();
      });

      document.getElementById('clearSessionBtn').addEventListener('click', () => {
        sessionStorage.removeItem('agentai_session');
        showToast('Session memory cleared.');
      });

      function showToast(msg = 'Settings saved.') {
        const t = document.getElementById('settingsSaved');
        t.querySelector ? null : null;
        t.innerHTML = `<i class="fas fa-circle-check"></i> ${msg}`;
        t.hidden = false;
        setTimeout(() => { t.hidden = true; }, 3000);
      }
    })();
    </script>
</body>
</html>
